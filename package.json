{
  "name": "@chesa/notification-service",
  "version": "0.1.0",
  "description": "Chesa standalone notification service — email, FCM push, WhatsApp-ready",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "dev:worker": "tsx watch --env-file=.env src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "start:worker": "node --env-file=.env dist/worker.js",
    "migrate": "tsx --env-file=.env scripts/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bullmq": "^5.34.0",
    "fastify": "^5.10.0",
    "firebase-admin": "^12.7.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.0",
    "mysql2": "^3.11.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
